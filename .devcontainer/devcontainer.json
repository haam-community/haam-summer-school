{
    "name": "Docsify Development",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        }
    },
    "postCreateCommand": "npm install -g docsify-cli",
    "postStartCommand": "docsify serve docs -p 3000",
    "forwardPorts": [3000],
    "runArgs": ["--expose=3000"]
}